# PostgreSQL connection string (Neon, Vercel Postgres, Supabase, or any Postgres
# host all work). Get one free at https://neon.tech — create a project, copy the
# "Connection string" it gives you. Looks like:
# postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=""

# Required for real AI scoring (technical / problem-solving / soft-skill narrative).
# If omitted, the app still works end-to-end using the rule-based scorer with a
# clearly-labeled fallback narrative instead of a Claude-generated one.
ANTHROPIC_API_KEY=

# Any long random string. Used to sign the employer session cookie.
SESSION_SECRET="change-me-to-a-long-random-string"
